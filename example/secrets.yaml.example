# =============================================================================
#  secrets.yaml  -  template
# =============================================================================
#  Copy this file to  secrets.yaml  (same folder as desk-lamp.yaml) and fill in
#  real values. Do NOT commit secrets.yaml to version control.
#
#  Generate strong values:
#    api_key       : 32-byte base64 key  ->  `openssl rand -base64 32`
#                    (or use the "key" button in the ESPHome dashboard)
#    ota_password  : any long random string
#    *_password    : your real passwords
# =============================================================================

wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"

# Password for the device's own fallback access point.
wifi_ap_password: "CHOOSE_A_FALLBACK_AP_PASSWORD"

# Home Assistant API encryption key (base64, 32 bytes).
api_key: "PASTE_BASE64_ENCRYPTION_KEY_HERE"

# OTA update password.
ota_password: "CHOOSE_AN_OTA_PASSWORD"
